{
  "version": 1,
  "hooks": {
    "postToolUse": [
      {
        "type": "command",
        "bash": "./scripts/hooks/post-tool-use.sh",
        "cwd": ".",
        "timeoutSec": 30,
        "matcher": "edit|create"
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "bash": "./scripts/hooks/stop-format-dirty.sh",
        "cwd": ".",
        "timeoutSec": 30
      }
    ]
  }
}
