#!/usr/bin/env bash
set -euo pipefail

if [[ $# -eq 0 ]]; then
  echo 'Usage: mise run source-to-project "<prompt>"' >&2
  exit 2
fi

prompt="$*"
dashboard_mode="${WEAVEKIT_DASHBOARD:-embedded}"
dashboard_url="${WEAVEKIT_DASHBOARD_URL:-}"

args=(
  --template source-to-project \
  --prompt "$prompt" \
  --mode advisory \
  --output runs
)

args+=(--project weavekit)

run_with_portless=false
case "$dashboard_mode" in
  embedded)
    if [[ -n "$dashboard_url" ]]; then
      args+=(--dashboard-url "$dashboard_url")
    else
      args+=(--dashboard)
      run_with_portless=true
    fi
    ;;
  off|none)
    ;;
  *)
    echo 'WEAVEKIT_DASHBOARD must be "embedded" or "off".' >&2
    exit 2
    ;;
esac

if [[ "$run_with_portless" == "true" ]]; then
  nubx portless run --name weavekit-source-to-project nub src/cli.ts workflow run "${args[@]}"
else
  nub src/cli.ts workflow run "${args[@]}"
fi
